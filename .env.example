# ============================================
# Smart Discharge Navigator
# Environment Configuration
# ============================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ============================================

# ============================================
# AI Agent Configuration (PRIMARY FEATURE)
# ============================================
# OpenAI API key — required for AI Agent features (chat, analysis, discharge plans)
# Get your key at: https://platform.openai.com/api-keys
# Without this key, the system runs in rule-based fallback mode (all core features still work)
OPENAI_API_KEY=sk-your-openai-api-key-here

# LLM model to use (gpt-4o)
AI_MODEL=gpt-4o

# Temperature: controls randomness (0.0 = deterministic, 1.0 = creative)
# Low values recommended for clinical use
AI_TEMPERATURE=0.3

# Maximum tokens in AI response
AI_MAX_TOKENS=2000

# Master toggle for AI features (true/false)
# Set to false to disable AI and run in rule-based mode only
AI_ENABLED=true

# ============================================
# FHIR Server Configuration
# ============================================
FHIR_BASE_URL=http://localhost:52773/fhir/r4
IRIS_USERNAME=SuperUser
IRIS_PASSWORD=SYS

# ============================================
# Application Configuration
# ============================================
CORS_ORIGINS=http://localhost:3000
DEBUG=True

# ============================================
# Risk Assessment Configuration (Rule-Based)
# ============================================
HIGH_RISK_THRESHOLD=0.7
MODERATE_RISK_THRESHOLD=0.4

# Risk Factor Weights (must sum to 1.0)
WEIGHT_RECENT_ADMISSIONS=0.25
WEIGHT_HIGH_RISK_CONDITIONS=0.20
WEIGHT_POLYPHARMACY=0.15
WEIGHT_AGE_FACTOR=0.15
WEIGHT_MISSED_FOLLOWUPS=0.15
WEIGHT_ABNORMAL_VITALS=0.10
